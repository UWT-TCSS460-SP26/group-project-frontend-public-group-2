# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. Never commit real secrets.

# ---- NextAuth core ----
# AUTH_SECRET: generate one with `npx auth secret` or `openssl rand -base64 33`
AUTH_SECRET=
# AUTH_URL: local dev = http://localhost:3000 ; Vercel = https://tcss460-group-2-consumer.vercel.app
AUTH_URL=http://localhost:3000

# ---- Auth² OIDC provider (Group 2 consumer client) ----
# AUTH_TCSS460_ID / AUTH_TCSS460_SECRET: provided by the instructor
AUTH_TCSS460_ID=
AUTH_TCSS460_SECRET=
# Issuer is fixed for the whole class. NO trailing slash.
AUTH_TCSS460_ISSUER=https://tcss-460-iam.onrender.com
# Audience: Group 1's API audience string (confirm with them; convention is group-1-api)
AUTH_TCSS460_AUDIENCE=group-1-api

# ---- Upstream partner (Group 1) API ----
# Group 1's deployed API base URL
NEXT_PUBLIC_API_BASE_URL=
