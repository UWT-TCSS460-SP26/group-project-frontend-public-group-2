# Copy to .env.local and fill in the blanks.

# ---- NextAuth core ----
# Generate with `npx auth secret` or `openssl rand -base64 33`
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ---- Auth² OIDC provider ----
AUTH_TCSS460_CLIENT_ID=group-2-consumer
AUTH_TCSS460_SECRET=
AUTH_TCSS460_ISSUER=https://tcss-460-iam.onrender.com
AUTH_TCSS460_AUDIENCE=group-1-api

# ---- Upstream partner (Group 1) API ----
NEXT_PUBLIC_API_BASE_URL=https://tcss460-team-1-api.onrender.com
